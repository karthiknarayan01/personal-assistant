.venv/
__pycache__/
*.pyc
*.egg-info/
.git/

# secrets / local state — mounted as volumes at runtime, never baked into the image
orchestrator/.env
credentials/*
!credentials/.gitkeep
sub_agents/shopping_agent/data/*
!sub_agents/shopping_agent/data/.gitkeep
sub_agents/remedy_agent/data/*
!sub_agents/remedy_agent/data/.gitkeep
