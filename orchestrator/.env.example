# Copy this file to orchestrator/.env and fill in real values.
# orchestrator/.env is gitignored — never commit it.

# --- Open-source LLM (via Ollama, running locally — no API key, no cost) ---
# Install Ollama (https://ollama.com) and pull a tool-calling-capable model:
#   ollama pull qwen2.5:14b
# qwen2.5:14b is the default (needs ~9GB disk, runs fine on 32GB RAM).
# Two smaller/weaker options were tried and rejected: llama3.1:8b silently
# narrated fake tool-call JSON as text instead of invoking tools at all
# (shopping_agent's 6-tool set); qwen2.5:7b invokes tools correctly but
# breaks down (empty/garbled output, or fabricates an answer instead of
# delegating) by the 3rd-4th turn of a multi-turn conversation, even with
# temperature=0. qwen2.5:14b held up across repeated multi-turn testing —
# don't downgrade without re-testing a multi-turn conversation, not just
# a single prompt.
# OLLAMA_API_BASE defaults to localhost; when running under Docker Compose
# on Mac/Windows, it's overridden to http://host.docker.internal:11434 so
# containers can reach Ollama running on the host (see docker-compose.yml).
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_API_BASE=http://localhost:11434

# --- A2A sub-agents ---
# Must match the port sub_agents/shopping_agent/server.py is run on.
SHOPPING_AGENT_PORT=8003
SHOPPING_AGENT_CARD_URL=http://localhost:8003/.well-known/agent-card.json

# Must match the port sub_agents/remedy_agent/server.py is run on.
REMEDY_AGENT_PORT=8004
REMEDY_AGENT_CARD_URL=http://localhost:8004/.well-known/agent-card.json
