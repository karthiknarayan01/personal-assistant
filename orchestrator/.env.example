# Copy this file to orchestrator/.env and fill in real values.
# orchestrator/.env is gitignored — never commit it.

# --- Gemini model access (get a key from https://aistudio.google.com/apikey) ---
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=

# --- A2A sub-agents ---
# Must match the port sub_agents/example_specialist/server.py is run on.
EXAMPLE_SPECIALIST_PORT=8001
EXAMPLE_SPECIALIST_AGENT_CARD_URL=http://localhost:8001/.well-known/agent-card.json

# Must match the port sub_agents/job_agent/server.py is run on.
JOB_AGENT_PORT=8002
JOB_AGENT_CARD_URL=http://localhost:8002/.well-known/agent-card.json

# Must match the port sub_agents/shopping_agent/server.py is run on.
SHOPPING_AGENT_PORT=8003
SHOPPING_AGENT_CARD_URL=http://localhost:8003/.well-known/agent-card.json

# Must match the port sub_agents/remedy_agent/server.py is run on.
REMEDY_AGENT_PORT=8004
REMEDY_AGENT_CARD_URL=http://localhost:8004/.well-known/agent-card.json
