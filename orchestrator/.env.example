# Copy this file to orchestrator/.env and fill in real values.
# orchestrator/.env is gitignored — never commit it.

# --- Gemini model access (get a key from https://aistudio.google.com/apikey) ---
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=

# --- Google Calendar OAuth (installed-app flow) ---
# Paths below are relative to the project root (where you run `adk web` /
# `adk run orchestrator` / `python scripts/authorize_calendar.py` from).
GOOGLE_CLIENT_SECRETS_FILE=credentials/client_secret.json
GOOGLE_TOKEN_FILE=credentials/token.json
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=UTC
